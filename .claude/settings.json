{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*autoskillit.*__run_skill.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m autoskillit.hooks.quota_check"
          },
          {
            "type": "command",
            "command": "python3 -m autoskillit.hooks.skill_command_guard"
          },
          {
            "type": "command",
            "command": "python3 /home/talon/projects/generic_automation_mcp/src/autoskillit/hooks/skill_command_guard.py"
          }
        ]
      },
      {
        "matcher": "mcp__.*autoskillit.*__remove_clone",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m autoskillit.hooks.remove_clone_guard"
          }
        ]
      },
      {
        "matcher": "^(Read|Write|Edit|Bash|Glob|Grep|Agent|WebFetch|WebSearch|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m autoskillit.hooks.native_tool_guard"
          }
        ]
      }
    ]
  }
}